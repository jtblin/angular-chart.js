{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./",
    "lib": ["DOM", "ES2020"],
    "types": ["mocha", "chai", "sinon", "sinon-chai", "angular", "angular-mocks"]
  },
  "include": ["src/**/*", "test/**/*", "examples/**/*"]
}
