{
  "name": "angular-chart.js",
  "version": "2.1.1",
  "description": "An angular.js wrapper for Chart.js",
  "homepage": "http://jtblin.github.io/angular-chart.js/",
  "main": "dist/angular-chart.js",
  "module": "dist/angular-chart.mjs",
  "exports": {
    ".": {
      "import": "./dist/angular-chart.mjs",
      "require": "./dist/angular-chart.js",
      "default": "./dist/angular-chart.js"
    }
  },
  "directories": {
    "example": "examples"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.mjs",
    "dist/*.mjs.map",
    "src/angular-chart.js"
  ],
  "scripts": {
    "test": "gulp check",
    "build": "rollup -c && gulp build",
    "dev": "rollup -c -w",
    "lint": "gulp lint",
    "release:patch": "gulp deploy-patch",
    "release:minor": "gulp deploy-minor",
    "release:major": "gulp deploy-major"
  },
  "author": "Jerome Touffe-Blin <jtblin@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/jtblin/angular-chart.js.git"
  },
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "angular-bootstrap": "^0.12.2",
    "angular-mocks": "^1.8.3",
    "bootstrap": "^3.3.7",
    "chai": "^4.3.7",
    "chai-string": "^1.5.0",
    "cp": "^0.2.0",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-angular": "^4.1.0",
    "font-awesome": "^4.7.0",
    "gulp": "^5.0.1",
    "gulp-bump": "^3.2.0",
    "gulp-eslint-new": "^2.6.2",
    "gulp-git": "^2.11.0",
    "gulp-gzip": "^1.4.2",
    "gulp-header": "^2.0.12",
    "gulp-mocha": "^10.0.1",
    "gulp-rename": "^2.1.0",
    "gulp-rimraf": "^1.0.0",
    "gulp-shell": "^0.8.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-tar": "^5.0.0",
    "gulp-uglify": "^3.0.2",
    "karma": "^6.4.4",
    "karma-chai": "^0.1.0",
    "karma-chrome-launcher": "^3.1.1",
    "karma-coverage": "^2.2.0",
    "karma-mocha": "^2.0.1",
    "karma-sinon": "^1.0.5",
    "karma-sinon-chai": "^2.0.2",
    "mkdirp": "^1.0.4",
    "mocha": "^11.7.5",
    "rainbow-code": "^2.1.7",
    "requirejs": "^2.3.6",
    "rollup": "^4.60.2",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^3.0.0",
    "sinon": "^15.0.1",
    "sinon-chai": "^3.7.0"
  },
  "dependencies": {
    "angular": "^1.8.3",
    "chart.js": "^2.9.4"
  }
}
